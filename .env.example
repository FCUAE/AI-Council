# ===========================================
# AI Council — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# Lines starting with # are comments.

# --- Database ---
DATABASE_URL=               # PostgreSQL connection string (required)

# --- Clerk Authentication ---
CLERK_SECRET_KEY=           # Clerk secret key for dev (required in dev)
CLERK_PUBLISHABLE_KEY=      # Clerk publishable key for dev (required in dev)
CLERK_PROD_SECRET_KEY=      # Clerk secret key for production (required in prod)
CLERK_PROD_PUBLISHABLE_KEY= # Clerk publishable key for production (required in prod)

# --- AI / LLM ---
AI_INTEGRATIONS_OPENROUTER_API_KEY=  # OpenRouter API key (required)
AI_INTEGRATIONS_OPENROUTER_BASE_URL= # OpenRouter base URL (optional, defaults to https://openrouter.ai/api/v1)

# --- Stripe Payments ---
# Stripe keys are managed via the Replit Stripe integration.
# If running outside Replit, set these manually:
# STRIPE_SECRET_KEY=        # Stripe secret key
# STRIPE_PUBLISHABLE_KEY=   # Stripe publishable key
# STRIPE_WEBHOOK_SECRET=    # Stripe webhook signing secret

# --- Email (Resend) ---
# Resend is managed via the Replit Resend integration.
# If running outside Replit, set manually:
# RESEND_API_KEY=           # Resend API key for transactional email
SUPPORT_EMAIL=              # Support email address (optional, defaults to support@askaicouncil.com)
UNSUBSCRIBE_SECRET=         # Secret for generating unsubscribe tokens (required)

# --- Admin ---
ADMIN_USER_IDS=             # Comma-separated Clerk user IDs with admin access (optional)

# --- App Settings ---
NODE_ENV=                   # "development" or "production" (optional)
PORT=                       # Server port (optional, defaults to 5000)
LOG_LEVEL=                  # Log level: debug, info, warn, error (optional)
SESSION_SECRET=             # Session secret for cookie signing (optional)

# --- Replit Platform (auto-set by Replit) ---
# REPLIT_DOMAINS=           # Comma-separated list of Replit domains
# REPLIT_DEV_DOMAIN=        # Dev domain for the Repl
# REPLIT_DEPLOYMENT=        # "1" when running in a deployment
# REPL_IDENTITY=            # Repl identity token
# PUBLIC_OBJECT_SEARCH_PATHS= # Object storage public paths
# PRIVATE_OBJECT_DIR=       # Object storage private directory

# --- Frontend (prefixed with VITE_) ---
VITE_CLERK_PUBLISHABLE_KEY= # Clerk publishable key for frontend (optional, falls back to /api/config)
